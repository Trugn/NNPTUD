{
  "info": {
    "_postman_id": "category-api-collection",
    "name": "Category API Collection",
    "description": "Complete Category API Testing Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Category - Public Routes",
      "item": [
        {
          "name": "Get Active Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories/active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "active"]
            },
            "description": "Get all active categories (Public - No authentication required)"
          },
          "response": []
        },
        {
          "name": "Get Category By Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories/slug/dien-tu",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "slug", "dien-tu"]
            },
            "description": "Get category by slug (Public - No authentication required)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Category - Authenticated Routes",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            },
            "description": "Get all categories (Authenticated users)"
          },
          "response": []
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            },
            "description": "Get category by ID (Authenticated users)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Category - Admin Routes",
      "item": [
        {
          "name": "Create Category (Without Image)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Điện Tử\",\n  \"description\": \"Các sản phẩm điện tử công nghệ cao\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            },
            "description": "Create new category without image (Admin only)"
          },
          "response": []
        },
        {
          "name": "Create Category (With Image)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Thời Trang",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Quần áo, giày dép và phụ kiện thời trang",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            },
            "description": "Create new category with image (Admin only)"
          },
          "response": []
        },
        {
          "name": "Update Category (Without Image)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Điện Tử - Cập nhật\",\n  \"description\": \"Các sản phẩm điện tử công nghệ cao - Cập nhật\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            },
            "description": "Update category without changing image (Admin only)"
          },
          "response": []
        },
        {
          "name": "Update Category (With Image)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Thời Trang - Cập nhật",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Quần áo, giày dép và phụ kiện thời trang - Cập nhật",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            },
            "description": "Update category with new image (Admin only)"
          },
          "response": []
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            },
            "description": "Delete category (Admin only)"
          },
          "response": []
        },
        {
          "name": "Toggle Category Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}/toggle-status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}", "toggle-status"]
            },
            "description": "Toggle category active/inactive status (Admin only)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_USER_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "YOUR_ADMIN_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "CATEGORY_ID_HERE",
      "type": "string"
    }
  ]
}
