    {
      "name": "User - Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    {\n      \"product\": \"PRODUCT_ID_1\",\n      \"quantity\": 2\n    },\n    {\n      \"product\": \"PRODUCT_ID_2\",\n      \"quantity\": 1\n    }\n  ],\n  \"shippingAddress\": {\n    \"fullName\": \"Nguyễn Văn A\",\n    \"phone\": \"0912345678\",\n    \"address\": \"123 Đường ABC\",\n    \"city\": \"TP. Hồ Chí Minh\",\n    \"district\": \"Quận 1\",\n    \"ward\": \"Phường 1\",\n    \"postalCode\": \"700001\"\n  },\n  \"paymentMethod\": \"cash_on_delivery\",\n  \"notes\": \"Ghi chú thêm\"\n}\n"
        },
        "url": {
          "raw": "http://localhost:5000/api/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "orders"]
        }
      }
    },
