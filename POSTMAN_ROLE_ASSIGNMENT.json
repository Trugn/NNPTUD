{
  "info": {
    "_postman_id": "role-assignment-collection",
    "name": "NNPTUD - Role Assignment API",
    "description": "API collection for assigning roles to users",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Register Admin User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin_user\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\",\n  \"passwordConfirm\": \"Admin@123\",\n  \"fullName\": \"Administrator\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Đăng ký user thường (sẽ là user role mặc định)"
          },
          "response": []
        },
        {
          "name": "2. Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/verify-email",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "auth",
                "verify-email"
              ]
            },
            "description": "Xác minh email (lấy token từ register response)"
          },
          "response": []
        },
        {
          "name": "3. Login as Admin User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Đăng nhập để lấy JWT token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "4. Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/users",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Lấy danh sách tất cả users (copy userId từ response)"
          },
          "response": []
        },
        {
          "name": "5. Assign Admin Role to User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"admin\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/users/{{userId}}/assign-role",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "users",
                "{{userId}}",
                "assign-role"
              ]
            },
            "description": "Gán role 'admin' cho user"
          },
          "response": []
        },
        {
          "name": "6. Assign Moderator Role to User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"moderator\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/users/{{userId}}/assign-role",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "users",
                "{{userId}}",
                "assign-role"
              ]
            },
            "description": "Gán role 'moderator' cho user"
          },
          "response": []
        },
        {
          "name": "7. Assign User Role to User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"user\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/users/{{userId}}/assign-role",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "users",
                "{{userId}}",
                "assign-role"
              ]
            },
            "description": "Gán role 'user' cho user"
          },
          "response": []
        },
        {
          "name": "8. Assign Guest Role to User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"guest\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/users/{{userId}}/assign-role",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "users",
                "{{userId}}",
                "assign-role"
              ]
            },
            "description": "Gán role 'guest' cho user"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT token sau khi login"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "ID của user cần assign role"
    },
    {
      "key": "verificationToken",
      "value": "",
      "type": "string",
      "description": "Token từ email verification"
    }
  ]
}
