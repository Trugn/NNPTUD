{
  "endpoints": [
    {
      "group": "Authentication (Public)",
      "endpoints": [
        {
          "name": "Register",
          "method": "POST",
          "path": "/api/auth/register",
          "description": "Create new user account",
          "body": {
            "username": "string (required, 3+ chars)",
            "email": "string (required, unique)",
            "password": "string (required, 6+ chars)",
            "passwordConfirm": "string (required)",
            "fullName": "string (optional)"
          },
          "response": 201,
          "fields": {
            "message": "string",
            "user": {
              "id": "string",
              "username": "string",
              "email": "string",
              "fullName": "string"
            },
            "verificationToken": "string"
          }
        },
        {
          "name": "Verify Email",
          "method": "POST",
          "path": "/api/auth/verify-email",
          "description": "Verify email with token",
          "body": {
            "token": "string (required)"
          },
          "response": 200,
          "fields": {
            "message": "string"
          }
        },
        {
          "name": "Login",
          "method": "POST",
          "path": "/api/auth/login",
          "description": "Login user and get tokens",
          "body": {
            "email": "string (required)",
            "password": "string (required)",
            "deviceName": "string (optional)"
          },
          "response": 200,
          "fields": {
            "message": "string",
            "accessToken": "string (JWT, valid 24h)",
            "refreshToken": "string (valid 7d)",
            "user": {
              "id": "string",
              "username": "string",
              "email": "string",
              "fullName": "string",
              "avatar": "string|null",
              "roles": "array"
            }
          }
        },
        {
          "name": "Refresh Token",
          "method": "POST",
          "path": "/api/auth/refresh-token",
          "description": "Get new access token",
          "body": {
            "refreshToken": "string (required)"
          },
          "response": 200,
          "fields": {
            "accessToken": "string (new JWT)",
            "refreshToken": "string (new refresh token)"
          }
        },
        {
          "name": "Forgot Password",
          "method": "POST",
          "path": "/api/auth/forgot-password",
          "description": "Request password reset",
          "body": {
            "email": "string (required)"
          },
          "response": 200,
          "fields": {
            "message": "string",
            "resetToken": "string (for testing only)"
          }
        },
        {
          "name": "Reset Password",
          "method": "POST",
          "path": "/api/auth/reset-password",
          "description": "Reset password with token",
          "body": {
            "token": "string (required)",
            "newPassword": "string (required, 6+ chars)",
            "confirmPassword": "string (required)"
          },
          "response": 200,
          "fields": {
            "message": "string"
          }
        }
      ]
    },
    {
      "group": "User Management (Protected)",
      "auth_required": "Bearer token",
      "endpoints": [
        {
          "name": "Get Current User",
          "method": "GET",
          "path": "/api/users/me",
          "description": "Get logged-in user profile",
          "response": 200,
          "fields": {
            "id": "string",
            "username": "string",
            "email": "string",
            "fullName": "string",
            "phone": "string|null",
            "avatar": "string|null",
            "isVerified": "boolean",
            "isActive": "boolean",
            "lastLogin": "date",
            "roles": "array",
            "createdAt": "date",
            "updatedAt": "date"
          }
        },
        {
          "name": "Get All Users",
          "method": "GET",
          "path": "/api/users",
          "description": "Get all users (paginated, requires permission)",
          "query": {
            "page": "number (default: 1)",
            "limit": "number (default: 10)",
            "search": "string (optional, search by username/email/fullName)"
          },
          "response": 200,
          "fields": {
            "users": "array",
            "pagination": {
              "total": "number",
              "page": "number",
              "limit": "number",
              "pages": "number"
            }
          },
          "permission": "read_user"
        },
        {
          "name": "Get User by ID",
          "method": "GET",
          "path": "/api/users/:id",
          "description": "Get specific user by ID",
          "response": 200,
          "fields": {
            "id": "string",
            "username": "string",
            "email": "string",
            "fullName": "string",
            "phone": "string|null",
            "avatar": "string|null",
            "isVerified": "boolean",
            "isActive": "boolean",
            "roles": "array"
          }
        },
        {
          "name": "Update User",
          "method": "PUT",
          "path": "/api/users/:id",
          "description": "Update user profile",
          "body": {
            "fullName": "string (optional)",
            "phone": "string (optional)"
          },
          "response": 200,
          "fields": {
            "message": "string",
            "user": {
              "id": "string",
              "username": "string",
              "email": "string",
              "fullName": "string",
              "phone": "string",
              "avatar": "string|null"
            }
          }
        },
        {
          "name": "Upload Avatar",
          "method": "POST",
          "path": "/api/users/upload-avatar",
          "description": "Upload user avatar image",
          "contentType": "multipart/form-data",
          "body": {
            "avatar": "file (JPEG, PNG, GIF, WebP, max 5MB)"
          },
          "response": 200,
          "fields": {
            "message": "string",
            "avatar": "string (URL path)",
            "user": {
              "id": "string",
              "username": "string",
              "email": "string",
              "fullName": "string",
              "avatar": "string"
            }
          }
        },
        {
          "name": "Change Password",
          "method": "POST",
          "path": "/api/users/change-password",
          "description": "Change user password",
          "body": {
            "currentPassword": "string (required)",
            "newPassword": "string (required, 6+ chars)",
            "confirmPassword": "string (required)"
          },
          "response": 200,
          "fields": {
            "message": "string"
          }
        },
        {
          "name": "Logout",
          "method": "POST",
          "path": "/api/users/logout",
          "description": "Logout user and revoke tokens",
          "body": {
            "refreshToken": "string (required)"
          },
          "response": 200,
          "fields": {
            "message": "string"
          }
        }
      ]
    },
    {
      "group": "Admin - User Management",
      "auth_required": "Bearer token + Admin role",
      "endpoints": [
        {
          "name": "Create User",
          "method": "POST",
          "path": "/api/users",
          "description": "Create new user (admin only)",
          "permission": "create_user",
          "body": {
            "username": "string (required)",
            "email": "string (required)",
            "password": "string (required)",
            "fullName": "string (optional)",
            "roles": "array (optional)"
          },
          "response": 201
        },
        {
          "name": "Delete User",
          "method": "DELETE",
          "path": "/api/users/:id",
          "description": "Delete user (admin only)",
          "permission": "delete_user",
          "response": 200
        },
        {
          "name": "Toggle User Status",
          "method": "PATCH",
          "path": "/api/users/:id/toggle-status",
          "description": "Activate/Deactivate user (admin only)",
          "permission": "update_user",
          "response": 200
        }
      ]
    },
    {
      "group": "System",
      "endpoints": [
        {
          "name": "Health Check",
          "method": "GET",
          "path": "/health",
          "description": "Check if server is running",
          "response": 200,
          "fields": {
            "status": "OK",
            "message": "Server is running"
          }
        }
      ]
    }
  ],
  "authentication": {
    "type": "JWT (Bearer Token)",
    "header": "Authorization: Bearer <access_token>",
    "accessTokenExpiry": "24 hours",
    "refreshTokenExpiry": "7 days"
  },
  "permissions": [
    {
      "name": "create_user",
      "description": "Create new users"
    },
    {
      "name": "read_user",
      "description": "View user list"
    },
    {
      "name": "update_user",
      "description": "Update user info"
    },
    {
      "name": "delete_user",
      "description": "Delete users"
    },
    {
      "name": "manage_roles",
      "description": "Manage roles"
    },
    {
      "name": "manage_permissions",
      "description": "Manage permissions"
    },
    {
      "name": "view_logs",
      "description": "View audit logs"
    },
    {
      "name": "export_data",
      "description": "Export data"
    }
  ],
  "roles": [
    {
      "name": "admin",
      "description": "Full access to all features"
    },
    {
      "name": "moderator",
      "description": "Limited admin features"
    },
    {
      "name": "user",
      "description": "Standard user features"
    },
    {
      "name": "guest",
      "description": "Read-only access"
    }
  ],
  "errorCodes": {
    "400": "Bad Request - Invalid input",
    "401": "Unauthorized - Token missing or invalid",
    "403": "Forbidden - Permission denied",
    "404": "Not Found - Resource not found",
    "409": "Conflict - Email/username already exists",
    "429": "Too Many Requests - Rate limited",
    "500": "Internal Server Error"
  }
}
